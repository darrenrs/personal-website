---
import Layout from "../layout/Layout.astro";
---

<Layout
  title="Contact | Darren R. Skidmore"
  description="Get in contact with Darren Skidmore."
>
  <section class="stack">
    <h1>Contact</h1>
    <p>
      Reach out to me on LinkedIn or GitHub if you'd like to talk, or send me an
      email directly!
    </p>
    <div class="grid contact-grid">
      <a
        class="card contact-card"
        href="https://www.linkedin.com/in/darrenrs0515"
        target="_blank"
        rel="noreferrer"
      >
        <span class="contact-icon" aria-hidden="true">
          <svg viewBox="0 0 24 24" fill="currentColor">
            <path
              d="M6.94 8.5A1.56 1.56 0 1 1 6.94 5.38a1.56 1.56 0 0 1 0 3.12ZM5.6 9.7h2.67V18H5.6V9.7Zm4.34 0h2.56v1.13h.04c.36-.67 1.23-1.38 2.52-1.38 2.7 0 3.2 1.78 3.2 4.1V18h-2.67v-3.95c0-.94-.02-2.16-1.31-2.16-1.32 0-1.52 1.03-1.52 2.09V18H9.94V9.7Z"
            ></path>
          </svg>
        </span>
        <h2>LinkedIn</h2>
        <p><code>darrenrs0515</code></p>
      </a>
      <a
        class="card contact-card"
        href="https://github.com/darrenrs"
        target="_blank"
        rel="noreferrer"
      >
        <span class="contact-icon" aria-hidden="true">
          <svg
            viewBox="0 0 24 24"
            width="24"
            height="24"
            fill="currentColor"
            xmlns="http://www.w3.org/2000/svg"
          >
            <path
              d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"
            ></path>
          </svg>
        </span>
        <h2>GitHub</h2>
        <p><code>darrenrs</code></p>
      </a>
      <a
        class="card contact-card contact-card-email"
        href="#"
        onclick="window.location.href = 'mailto: darrenrs0515@gmail.com'; return false;"
      >
        <span class="contact-icon" aria-hidden="true">
          <svg
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="1.8"
          >
            <rect x="3.5" y="5.5" width="17" height="13" rx="2"></rect>
            <path d="M4.5 7l7.5 6 7.5-6"></path>
          </svg>
        </span>
        <h2>Email</h2>
        <p>
          <code
            class="contact-email"
            data-name="darrenrs0515"
            data-domain="gmail"
            data-tld="com"></code>
        </p>
      </a>
    </div>
  </section>
</Layout>
